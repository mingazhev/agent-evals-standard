{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agent-evals-standard:schema:conformance-statement:2",
  "title": "Agent Evals Golden Standard signed conformance statement",
  "type": "object",
  "required": [
    "schemaVersion",
    "standardRelease",
    "contracts",
    "schemas",
    "claim",
    "scope",
    "targetEvidence",
    "evidenceManifest",
    "extensions",
    "deviations",
    "claimRestrictions",
    "issuer",
    "issuedAt",
    "reviewAt",
    "signature"
  ],
  "properties": {
    "schemaVersion": { "const": "agent-eval-conformance-statement-2" },
    "standardRelease": {
      "type": "object",
      "required": ["version", "tag", "commit"],
      "properties": {
        "version": { "const": "4.0.0" },
        "tag": { "const": "v4.0.0" },
        "commit": { "type": "string", "pattern": "^[a-f0-9]{40,64}$" }
      },
      "additionalProperties": false
    },
    "contracts": {
      "type": "object",
      "required": ["scorecard", "governancePolicy", "escalationStopMatrix", "case", "environment", "semanticValidation"],
      "properties": {
        "scorecard": {
          "allOf": [
            { "$ref": "#/$defs/contractArtifact" },
            { "properties": { "id": { "const": "scorecard-contract" }, "version": { "const": "3.0.0" }, "kind": { "const": "standard" } } }
          ]
        },
        "governancePolicy": { "$ref": "#/$defs/contractArtifact" },
        "escalationStopMatrix": { "$ref": "#/$defs/contractArtifact" },
        "case": {
          "allOf": [
            { "$ref": "#/$defs/contractArtifact" },
            { "properties": { "id": { "const": "case-contract" }, "version": { "const": "3.0.0" }, "kind": { "const": "standard" } } }
          ]
        },
        "environment": { "$ref": "#/$defs/contractArtifact" },
        "semanticValidation": {
          "allOf": [
            { "$ref": "#/$defs/contractArtifact" },
            { "properties": { "id": { "const": "semantic-validation" }, "version": { "const": "semantic-validation-2.0.0" }, "kind": { "const": "standard" } } }
          ]
        }
      },
      "additionalProperties": false
    },
    "schemas": {
      "type": "object",
      "required": ["case", "caseQaRecord", "scorecard", "conformanceStatement", "escalationEvent", "assuranceObservation", "governanceResolution", "governanceResolutionLedger", "governanceDecision"],
      "properties": {
        "case": { "const": "agent-eval-case-3" },
        "caseQaRecord": { "const": "case-qa-record-3" },
        "scorecard": { "const": "agent-eval-scorecard-4" },
        "conformanceStatement": { "const": "agent-eval-conformance-statement-2" },
        "escalationEvent": { "const": "agent-eval-escalation-event-2" },
        "assuranceObservation": { "const": "agent-eval-assurance-observation-1" },
        "governanceResolution": { "const": "agent-eval-governance-resolution-2" },
        "governanceResolutionLedger": { "const": "agent-eval-governance-resolution-ledger-2" },
        "governanceDecision": { "const": "agent-eval-governance-decision-2" }
      },
      "additionalProperties": false
    },
    "claim": { "enum": ["case", "evaluator", "run", "decision", "full"] },
    "scope": { "type": "string", "minLength": 1 },
    "implementation": {
      "type": "object",
      "required": ["name", "version", "commit", "digest"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "commit": { "type": "string", "minLength": 7 },
        "digest": { "$ref": "#/$defs/digest" }
      },
      "additionalProperties": false
    },
    "targetEvidence": {
      "type": "object",
      "properties": {
        "case": { "$ref": "#/$defs/targetResult" },
        "evaluator": { "$ref": "#/$defs/targetResult" },
        "run": { "$ref": "#/$defs/targetResult" },
        "decision": { "$ref": "#/$defs/targetResult" }
      },
      "additionalProperties": false
    },
    "evidenceManifest": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/evidenceArtifact" }
    },
    "decisionEnvelope": {
      "type": "object",
      "required": ["decisionRecord", "approvalEnvelope", "policyInstance", "matrixInstance", "effectiveAt", "reviewAt", "expiresAt", "approvers"],
      "properties": {
        "decisionRecord": { "$ref": "#/$defs/artifactRef" },
        "approvalEnvelope": { "$ref": "#/$defs/artifactRef" },
        "policyInstance": { "$ref": "#/$defs/artifactRef" },
        "matrixInstance": { "$ref": "#/$defs/artifactRef" },
        "postDecisionAssurancePlan": { "$ref": "#/$defs/artifactRef" },
        "effectiveAt": { "type": "string", "format": "date-time" },
        "reviewAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "approvers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "role", "attestation"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "role": { "type": "string", "minLength": 1 },
              "attestation": { "$ref": "#/$defs/signature" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "extensions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["namespace", "version"],
        "properties": {
          "namespace": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]*$" },
          "version": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": true
      }
    },
    "deviations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rule", "description", "impact", "affectedTargets", "restrictionIds"],
        "properties": {
          "rule": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "impact": { "type": "string", "minLength": 1 },
          "affectedTargets": {
            "type": "array",
            "minItems": 1,
            "items": { "enum": ["case", "evaluator", "run", "decision"] },
            "uniqueItems": true
          },
          "restrictionIds": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
        },
        "additionalProperties": false
      }
    },
    "claimRestrictions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "claim", "reason"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "claim": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "issuer": {
      "type": "object",
      "required": ["id", "name", "verificationMethod"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "verificationMethod": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "issuedAt": { "type": "string", "format": "date-time" },
    "reviewAt": { "type": "string", "format": "date-time" },
    "signature": { "$ref": "#/$defs/signature" }
  },
  "allOf": [
    {
      "if": { "properties": { "claim": { "enum": ["evaluator", "run", "decision", "full"] } }, "required": ["claim"] },
      "then": { "required": ["implementation"] }
    },
    {
      "if": { "properties": { "claim": { "const": "case" } }, "required": ["claim"] },
      "then": { "properties": { "targetEvidence": { "required": ["case"] } } }
    },
    {
      "if": { "properties": { "claim": { "const": "evaluator" } }, "required": ["claim"] },
      "then": { "properties": { "targetEvidence": { "required": ["evaluator"] } } }
    },
    {
      "if": { "properties": { "claim": { "const": "run" } }, "required": ["claim"] },
      "then": { "properties": { "targetEvidence": { "required": ["run"] } } }
    },
    {
      "if": { "properties": { "claim": { "enum": ["decision", "full"] } }, "required": ["claim"] },
      "then": {
        "required": ["decisionEnvelope"],
        "properties": {
          "targetEvidence": { "required": ["decision"] },
          "contracts": {
            "properties": {
              "governancePolicy": { "properties": { "kind": { "const": "operational" } } },
              "escalationStopMatrix": { "properties": { "kind": { "const": "operational" } } }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "claim": { "const": "full" } }, "required": ["claim"] },
      "then": { "properties": { "targetEvidence": { "required": ["case", "evaluator", "run", "decision"] } } }
    },
    {
      "if": { "properties": { "deviations": { "minItems": 1 } }, "required": ["deviations"] },
      "then": { "properties": { "claimRestrictions": { "minItems": 1 } } }
    }
  ],
  "additionalProperties": false,
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "artifactRef": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$" },
    "signature": {
      "type": "object",
      "required": ["algorithm", "keyId", "value"],
      "properties": {
        "algorithm": { "type": "string", "minLength": 1 },
        "keyId": { "type": "string", "minLength": 1 },
        "value": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "contractArtifact": {
      "type": "object",
      "required": ["id", "version", "kind", "location", "digest"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["standard", "template", "operational"] },
        "location": { "type": "string", "minLength": 1 },
        "digest": { "$ref": "#/$defs/digest" }
      },
      "additionalProperties": false
    },
    "targetResult": {
      "type": "object",
      "required": ["status", "evidence"],
      "properties": {
        "status": { "const": "conforming" },
        "evidence": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/artifactRef" }, "uniqueItems": true }
      },
      "additionalProperties": false
    },
    "evidenceArtifact": {
      "type": "object",
      "required": ["id", "location", "digest", "mediaType", "issuer", "createdAt"],
      "properties": {
        "id": { "$ref": "#/$defs/artifactRef" },
        "location": { "type": "string", "minLength": 1 },
        "digest": { "$ref": "#/$defs/digest" },
        "mediaType": { "type": "string", "minLength": 1 },
        "issuer": { "type": "string", "minLength": 1 },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    }
  }
}
