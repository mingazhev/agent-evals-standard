{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agent-evals-standard:schema:case-qa-record:2",
  "title": "Agent eval case QA activation record",
  "type": "object",
  "required": [
    "schemaVersion",
    "case",
    "contracts",
    "stages",
    "defects",
    "controlProofs",
    "alternativeSolutionEvidence",
    "stabilityProofs",
    "measurementValidation",
    "decision",
    "recordHash"
  ],
  "properties": {
    "schemaVersion": { "const": "case-qa-record-2" },
    "case": {
      "type": "object",
      "required": ["id", "version", "hash", "fromState", "toState"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "hash": { "$ref": "#/$defs/digest" },
        "fromState": { "enum": ["candidate", "active", "quarantined", "saturated", "regression"] },
        "toState": { "enum": ["active", "candidate", "quarantined"] }
      },
      "additionalProperties": false
    },
    "contracts": {
      "type": "object",
      "required": [
        "goldenStandardVersion",
        "scorecardContractVersion",
        "caseContractVersion",
        "environmentContractVersion",
        "governancePolicyVersion",
        "escalationStopMatrixVersion",
        "profileVersion",
        "graderSetHash",
        "semanticValidationVersion"
      ],
      "properties": {
        "goldenStandardVersion": { "const": "3.0.1" },
        "scorecardContractVersion": { "const": "2.0.0" },
        "caseContractVersion": { "const": "2.0.0" },
        "environmentContractVersion": { "type": "string", "minLength": 1 },
        "governancePolicyVersion": { "type": "string", "minLength": 1 },
        "escalationStopMatrixVersion": { "type": "string", "minLength": 1 },
        "profileVersion": { "type": "string", "minLength": 1 },
        "graderSetHash": { "$ref": "#/$defs/digest" },
        "semanticValidationVersion": { "const": "semantic-validation-1.0.0" }
      },
      "additionalProperties": true
    },
    "stages": {
      "type": "array",
      "minItems": 9,
      "maxItems": 9,
      "prefixItems": [
        { "$ref": "#/$defs/stage0" },
        { "$ref": "#/$defs/stage1" },
        { "$ref": "#/$defs/stage2" },
        { "$ref": "#/$defs/stage3" },
        { "$ref": "#/$defs/stage4" },
        { "$ref": "#/$defs/stage5" },
        { "$ref": "#/$defs/stage6" },
        { "$ref": "#/$defs/stage7" },
        { "$ref": "#/$defs/stage8" }
      ],
      "items": false
    },
    "defects": {
      "type": "array",
      "items": { "$ref": "#/$defs/defect" }
    },
    "controlProofs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/evidence" }
    },
    "alternativeSolutionEvidence": { "$ref": "#/$defs/evidence" },
    "stabilityProofs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "allOf": [
          { "$ref": "#/$defs/evidence" },
          {
            "type": "object",
            "required": ["checkId", "repetitionCount", "environment", "observedFailureRate", "permittedThreshold", "quarantineTrigger"],
            "properties": {
              "checkId": { "type": "string", "minLength": 1 },
              "repetitionCount": { "type": "integer", "minimum": 1 },
              "environment": { "type": "string", "minLength": 1 },
              "observedFailureRate": { "type": "number", "minimum": 0, "maximum": 1 },
              "permittedThreshold": { "type": "number", "minimum": 0, "maximum": 1 },
              "quarantineTrigger": { "type": "string", "minLength": 1 }
            }
          }
        ]
      }
    },
    "measurementValidation": {
      "type": "object",
      "required": ["protocolVersion", "validationDate", "expiresAt", "coverage", "falsePositive", "falseNegative", "semanticValidationEvidence"],
      "properties": {
        "protocolVersion": { "type": "string", "minLength": 1 },
        "validationDate": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "coverage": { "type": "string", "minLength": 1 },
        "falsePositive": { "$ref": "#/$defs/rateValidation" },
        "falseNegative": { "$ref": "#/$defs/rateValidation" },
        "semanticValidationEvidence": { "$ref": "#/$defs/evidence" }
      },
      "additionalProperties": false
    },
    "decision": {
      "type": "object",
      "required": ["status", "approver", "timestamp", "unresolvedBlockingDefects"],
      "properties": {
        "status": { "enum": ["activated", "rejected"] },
        "approver": { "type": "string", "minLength": 1 },
        "timestamp": { "type": "string", "format": "date-time" },
        "unresolvedBlockingDefects": { "type": "integer", "minimum": 0 }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "activated" } }, "required": ["status"] },
          "then": { "properties": { "unresolvedBlockingDefects": { "const": 0 } } }
        }
      ],
      "additionalProperties": true
    },
    "invalidation": {
      "type": ["object", "null"],
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "reason": { "type": "string", "minLength": 1 },
        "supersedingRecord": { "type": ["string", "null"] }
      },
      "required": ["timestamp", "reason"],
      "additionalProperties": false
    },
    "recordHash": {
      "type": "string",
      "pattern": "^sha256-jcs-v1:[a-f0-9]{64}$"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "case": {
            "properties": { "toState": { "const": "active" } },
            "required": ["toState"]
          }
        },
        "required": ["case"]
      },
      "then": {
        "properties": {
          "case": {
            "properties": {
              "fromState": { "enum": ["candidate", "quarantined"] }
            }
          },
          "decision": {
            "properties": { "status": { "const": "activated" } }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "decision": {
            "properties": { "status": { "const": "activated" } },
            "required": ["status"]
          }
        },
        "required": ["decision"]
      },
      "then": {
        "properties": {
          "case": {
            "properties": { "toState": { "const": "active" } }
          },
          "stages": {
            "items": {
              "properties": { "status": { "const": "passed" } }
            }
          },
          "defects": {
            "items": {
              "not": {
                "properties": {
                  "severity": { "enum": [2, 3] },
                  "status": { "enum": ["open", "accepted_minor"] }
                },
                "required": ["severity", "status"]
              }
            }
          },
          "measurementValidation": {
            "properties": {
              "falsePositive": { "properties": { "status": { "const": "pass" } } },
              "falseNegative": { "properties": { "status": { "const": "pass" } } }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false,
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "evidence": {
      "type": "object",
      "required": ["artifact", "hash"],
      "properties": {
        "artifact": { "type": "string", "minLength": 1 },
        "hash": { "$ref": "#/$defs/digest" }
      },
      "additionalProperties": true
    },
    "stage": {
      "type": "object",
      "required": ["id", "status", "reviewer", "reviewerRole", "timestamp", "evidence", "findings"],
      "properties": {
        "id": { "type": "integer", "minimum": 0, "maximum": 8 },
        "status": { "enum": ["passed", "failed"] },
        "reviewer": { "type": "string", "minLength": 1 },
        "reviewerRole": { "type": "string", "minLength": 1 },
        "timestamp": { "type": "string", "format": "date-time" },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evidence" }
        },
        "findings": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "stage0": { "allOf": [{ "$ref": "#/$defs/stage" }, { "properties": { "id": { "const": 0 } } }] },
    "stage1": { "allOf": [{ "$ref": "#/$defs/stage" }, { "properties": { "id": { "const": 1 } } }] },
    "stage2": { "allOf": [{ "$ref": "#/$defs/stage" }, { "properties": { "id": { "const": 2 } } }] },
    "stage3": { "allOf": [{ "$ref": "#/$defs/stage" }, { "properties": { "id": { "const": 3 } } }] },
    "stage4": { "allOf": [{ "$ref": "#/$defs/stage" }, { "properties": { "id": { "const": 4 } } }] },
    "stage5": { "allOf": [{ "$ref": "#/$defs/stage" }, { "properties": { "id": { "const": 5 } } }] },
    "stage6": { "allOf": [{ "$ref": "#/$defs/stage" }, { "properties": { "id": { "const": 6 } } }] },
    "stage7": { "allOf": [{ "$ref": "#/$defs/stage" }, { "properties": { "id": { "const": 7 } } }] },
    "stage8": { "allOf": [{ "$ref": "#/$defs/stage" }, { "properties": { "id": { "const": 8 } } }] },
    "rateValidation": {
      "type": "object",
      "required": ["sampleSize", "estimate", "intervalMethod", "confidenceLevel", "lower", "upper", "threshold", "thresholdRule", "status", "rawEvidence", "calculationContract"],
      "properties": {
        "sampleSize": { "type": "integer", "minimum": 1 },
        "estimate": { "type": "number", "minimum": 0, "maximum": 1 },
        "intervalMethod": { "type": "string", "minLength": 1 },
        "confidenceLevel": { "type": "number", "exclusiveMinimum": 0, "exclusiveMaximum": 1 },
        "lower": { "type": "number", "minimum": 0, "maximum": 1 },
        "upper": { "type": "number", "minimum": 0, "maximum": 1 },
        "threshold": { "type": "number", "minimum": 0, "maximum": 1 },
        "thresholdRule": { "type": "string", "minLength": 1 },
        "status": { "enum": ["pass", "breach", "insufficient_evidence"] },
        "rawEvidence": { "$ref": "#/$defs/evidence" },
        "calculationContract": { "$ref": "#/$defs/evidence" }
      },
      "additionalProperties": false
    },
    "defect": {
      "type": "object",
      "required": ["id", "type", "severity", "status"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "severity": { "type": "integer", "minimum": 0, "maximum": 3 },
        "status": { "enum": ["open", "fixed", "accepted_minor"] },
        "fixEvidence": { "$ref": "#/$defs/evidence" }
      },
      "additionalProperties": true
    }
  }
}
